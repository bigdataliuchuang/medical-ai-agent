# =============================================================================
# Medical AI Agent — Environment Variables
# Copy to .env and fill in actual values before running.
# =============================================================================

# --- LLM (Claude for SQL generation & intent classification) ---
ANTHROPIC_API_KEY=sk-ant-xxxx
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=30

# --- Doris (OLAP query target, ADS layer only) ---
DORIS_HOST=192.168.241.128
DORIS_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=
DORIS_DATABASE=ads
DORIS_QUERY_TIMEOUT=30
DORIS_MAX_ROWS=100

# --- Milvus (vector store for schema retrieval) ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=medical_schema

# --- Embedding model (local, no API key needed) ---
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- Security ---
SQL_WHITELIST_TABLES=ads_dq_result_summary,ads_patient_mpi_summary,ads_drug_usage_trend,ads_tumor_report_monthly,ads_expense_by_tumor_type,ads_inpatient_quality_board,dq_check_result,dq_issue_detail,mpi_cross_reference

# --- Session ---
SESSION_MAX_TURNS=10
SESSION_TIMEOUT_MINUTES=30
